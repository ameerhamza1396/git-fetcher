{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/api/seq_ai",
      "destination": "/api/seq_ai.ts"
    },
    {
      "source": "/api/reference",
      "destination": "/api/reference.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}